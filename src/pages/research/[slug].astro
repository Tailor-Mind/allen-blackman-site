---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PdfPreview from '../../components/PdfPreview.astro';
import AttachmentsList from '../../components/AttachmentsList.astro';
import RelatedEntriesList from '../../components/RelatedEntriesList.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Look up the category label
const categoryEntry = await getEntry('projectCategories', project.data.category);
const categoryLabel = categoryEntry?.data.label || project.data.category;

// Resolve related entries, filtering out archived
async function resolveEntries<C extends 'publications' | 'webtools' | 'blog'>(
  collectionName: C,
  ids: string[]
) {
  const resolved = await Promise.all(
    ids.map((id) => getEntry(collectionName, id))
  );
  return resolved.filter(
    (e): e is NonNullable<typeof e> => !!e && !e.data.archived
  );
}

const relatedPubs = project.data.showLinkedPublications
  ? await resolveEntries('publications', project.data.relatedPublications)
  : [];
const relatedWebtools = project.data.showLinkedWebtools
  ? await resolveEntries('webtools', project.data.relatedWebtools)
  : [];
const relatedBlog = project.data.showLinkedBlog
  ? await resolveEntries('blog', project.data.relatedBlog)
  : [];

const featuredIsPdf =
  !!project.data.featuredDocument &&
  project.data.featuredDocument.toLowerCase().endsWith('.pdf');
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article>
    <p style="margin-bottom: 1rem;"><a href="/research">&larr; All Research</a></p>

    <h1>{project.data.title}</h1>

    <p>
      <span class="tag">{project.data.status === 'active' ? 'Active' : 'Completed'}</span>
      <span class="tag">{categoryLabel}</span>
    </p>

    <p style="margin-top: 1rem;">{project.data.description}</p>

    {project.data.collaborators && project.data.collaborators.length > 0 && (
      <section style="margin-top: 1.5rem;">
        <h2>Collaborators</h2>
        <ul style="padding-left: 1.5rem;">
          {project.data.collaborators.map((c: { name: string; institution?: string }) => (
            <li>{c.name}{c.institution ? ` (${c.institution})` : ''}</li>
          ))}
        </ul>
      </section>
    )}

    {project.data.funding && (
      <p style="margin-top: 1rem;"><strong>Funding:</strong> {project.data.funding}</p>
    )}

    {project.body && (
      <section class="prose" style="margin-top: 1.5rem;">
        <Content />
      </section>
    )}

    {featuredIsPdf && (
      <section style="margin-top: 2rem;">
        <h2>{project.data.featuredDocumentLabel || 'Featured Document'}</h2>
        {project.data.featuredDocumentDescription && (
          <p style="color: var(--color-text-muted);">{project.data.featuredDocumentDescription}</p>
        )}
        <PdfPreview
          src={project.data.featuredDocument}
          title={project.data.featuredDocumentLabel || project.data.title}
          downloadLabel="Download PDF"
        />
      </section>
    )}

    <RelatedEntriesList
      heading="Related Publications"
      entries={relatedPubs.map((p) => ({
        id: p.id,
        title: p.data.title,
        href: `/publications/${p.id}`,
        subtitle: `${p.data.authors.join(', ')} (${p.data.year})`,
      }))}
    />

    <RelatedEntriesList
      heading="Related Webtools"
      entries={relatedWebtools.map((w) => ({
        id: w.id,
        title: w.data.title,
        href: `/webtools/${w.id}`,
      }))}
    />

    <RelatedEntriesList
      heading="Related Blog Posts"
      entries={relatedBlog.map((p) => ({
        id: p.id,
        title: p.data.title,
        href: `/blog/${p.id}`,
        subtitle: p.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
      }))}
    />

    {project.data.attachments && project.data.attachments.length > 0 && (
      <AttachmentsList attachments={project.data.attachments} heading="Resources" />
    )}
  </article>
</BaseLayout>
