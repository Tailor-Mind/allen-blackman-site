---
interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
}

const { id, title, description, pubDate, heroImage, tags } = Astro.props;

const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card">
  {heroImage && (
    <img src={heroImage} alt="" style="width: 100%; height: 180px; object-fit: cover; border-radius: 3px; margin-bottom: 0.75rem;" loading="lazy" />
  )}
  <h3><a href={`/blog/${id}`}>{title}</a></h3>
  <p class="meta">{dateStr}</p>
  <p>{description}</p>
  {tags && tags.length > 0 && (
    <div style="margin-top: 0.5rem;">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>
