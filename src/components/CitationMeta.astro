---
import { parsePages, formatCitationDate } from '../lib/utils';

interface Props {
  title: string;
  authors: string[];
  year: number;
  publicationDate?: Date;
  journal?: string;
  volume?: string;
  issue?: string;
  pages?: string;
  doi?: string;
  pdfUrl?: string;
  issn?: string;
  language?: string;
}

const {
  title,
  authors,
  year,
  publicationDate,
  journal,
  volume,
  issue,
  pages,
  doi,
  pdfUrl,
  issn,
  language = 'en',
} = Astro.props;

const { first: firstPage, last: lastPage } = parsePages(pages);
const citationDate = formatCitationDate(year, publicationDate);

// Build absolute PDF URL if relative
let absolutePdfUrl = pdfUrl;
if (pdfUrl && !pdfUrl.startsWith('http') && Astro.site) {
  absolutePdfUrl = new URL(pdfUrl, Astro.site).href;
}
---

<meta name="citation_title" content={title} />
{authors.map((author) => (
  <meta name="citation_author" content={author} />
))}
<meta name="citation_publication_date" content={citationDate} />
{journal && <meta name="citation_journal_title" content={journal} />}
{volume && <meta name="citation_volume" content={volume} />}
{issue && <meta name="citation_issue" content={issue} />}
{firstPage && <meta name="citation_firstpage" content={firstPage} />}
{lastPage && <meta name="citation_lastpage" content={lastPage} />}
{doi && <meta name="citation_doi" content={doi} />}
{absolutePdfUrl && <meta name="citation_pdf_url" content={absolutePdfUrl} />}
{issn && <meta name="citation_issn" content={issn} />}
<meta name="citation_language" content={language} />
